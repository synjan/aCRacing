# Caddyfile – Reverse proxy for AC server web services
# Plasser i /etc/caddy/Caddyfile
# IP-basert oppsett (uten domene)

# ── Admin dashboard – http://46.225.176.106:8080 ─────────────────
# Alt proxyes til Express (auth, API, statiske filer)
:8080 {
  reverse_proxy localhost:3001

  log {
    output file /var/log/caddy/admin-access.log
  }

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
  }
}

# ── Stracker stats (separat port per instans for korrekt routing) ──
# Stracker kjenner ikke til path-prefixer, sa egne porter unngår
# redirect-problemer der /mx5cup/mainpage → /mainpage

(stracker_headers) {
  log {
    output file /var/log/caddy/stats-access.log
  }
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy no-referrer
  }
}

# Trackday stats – http://46.225.176.106:8081
:8081 {
  reverse_proxy localhost:50041
  import stracker_headers
}

# MX-5 Cup stats – http://46.225.176.106:8082
:8082 {
  reverse_proxy localhost:50042
  import stracker_headers
}

# GT3 stats – http://46.225.176.106:8083
:8083 {
  reverse_proxy localhost:50043
  import stracker_headers
}

# ─────────────────────────────────────────────────────────────────
# INSTALLASJON:
# sudo apt install caddy
# sudo cp Caddyfile /etc/caddy/Caddyfile
# sudo systemctl enable --now caddy
#
# Dashboard:  http://46.225.176.106:8080 → Express (:3001)
# Stats:      http://46.225.176.106:8081  (trackday)
#             http://46.225.176.106:8082  (mx5cup)
#             http://46.225.176.106:8083  (gt3)
